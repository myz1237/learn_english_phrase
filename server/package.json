{
  "name": "phrasebook-server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:local": "DB_DRIVER=sqlite NODE_OPTIONS='--experimental-sqlite --disable-warning=ExperimentalWarning' tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "seed": "tsx src/seed.ts",
    "seed:local": "DB_DRIVER=sqlite NODE_OPTIONS='--experimental-sqlite --disable-warning=ExperimentalWarning' tsx src/seed.ts",
    "validate": "tsx ../content/validate.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "mongoose": "^8.9.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
