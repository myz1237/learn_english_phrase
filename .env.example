# Phrasebook 环境配置示例
# ──────────────────────────────────────────────────────────
# 完全本地模式(npm run dev:local,SQLite)不需要本文件,开箱即用。
# 仅 MongoDB 模式(npm run dev)需要:复制本文件为项目根目录的 .env 再修改:
#   cp .env.example .env

# MongoDB 连接串(Mongo 模式必填)
MONGO_URL=mongodb://localhost:27017

# 数据库名(可选,默认 phrasebook)
# MONGO_DB=phrasebook

# 后端端口(可选,默认 3001)
# PORT=3001

# SQLite 数据文件路径(可选,仅本地模式;默认 server/data/phrasebook.sqlite)
# SQLITE_PATH=/absolute/path/to/phrasebook.sqlite
